{
  "id": "echelon",
  "name": "Echelon Bike",
  "description": "Echelon indoor bike proprietary format. Reference: https://github.com/UCF-SDTeam13/echelon-bike",

  "serviceUuid": "0bf669f0-45f2-11e7-9598-0800200c9a66",
  "characteristicUuid": "0bf669f4-45f2-11e7-9598-0800200c9a66",

  "initWrites": [
    {
      "characteristicUuid": "0bf669f2-45f2-11e7-9598-0800200c9a66",
      "bytes": [240, 176, 1, 1, 162],
      "comment": "Activation command — tells the bike to start streaming workout data"
    }
  ],

  "packets": [
    {
      "comment": "D1 packet — cadence and heart rate",
      "validation": { "magicBytes": [{ "offset": 1, "value": 209 }] },
      "minLength": 12,
      "fields": [
        {
          "name": "cadence",
          "offset": 9,
          "type": "uint16",
          "endian": "big",
          "comment": "Cadence in RPM (big-endian uint16)"
        },
        {
          "name": "heartRate",
          "offset": 11,
          "type": "uint8",
          "condition": { "min": 1, "max": 250 },
          "comment": "Heart rate from connected HR strap"
        }
      ]
    },
    {
      "comment": "D2 packet — resistance level",
      "validation": { "magicBytes": [{ "offset": 1, "value": 210 }] },
      "minLength": 4,
      "fields": [
        {
          "name": "resistance",
          "offset": 3,
          "type": "uint8",
          "comment": "Resistance level 0-32"
        }
      ]
    }
  ],

  "computed": [
    {
      "name": "_resFactor",
      "operation": "exponential",
      "operands": ["resistance"],
      "base": 1.090112,
      "comment": "1.090112^resistance — exponential resistance component"
    },
    {
      "name": "_cadFactor",
      "operation": "exponential",
      "operands": ["cadence"],
      "base": 1.015343,
      "comment": "1.015343^cadence — exponential cadence component"
    },
    {
      "name": "power",
      "operation": "multiply",
      "operands": ["cadence", "resistance"],
      "factor": 0.08,
      "comment": "Estimated power — computed from accumulated cadence (D1) × resistance (D2)"
    }
  ]
}
