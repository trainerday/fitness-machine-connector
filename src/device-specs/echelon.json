{
  "id": "echelon",
  "name": "Echelon Bike",
  "description": "Echelon indoor bike proprietary format. Reference: https://github.com/UCF-SDTeam13/echelon-bike",

  "serviceUuid": "0bf669f0-45f2-11e7-9598-0800200c9a66",
  "characteristicUuid": "0bf669f4-45f2-11e7-9598-0800200c9a66",

  "minLength": 4,

  "fields": [
    {
      "name": "resistance",
      "offset": 3,
      "type": "uint8",
      "condition": {
        "byteEquals": { "offset": 1, "value": 210 },
        "min": 1,
        "max": 32
      },
      "comment": "Resistance level 1-32. Only present in 0xd2 (210) packets. 0xd1 packets have a sequence counter at byte 3, not resistance."
    },
    {
      "name": "cadence",
      "offset": 9,
      "type": "uint16",
      "endian": "big",
      "comment": "Cadence in RPM (big-endian)"
    },
    {
      "name": "heartRate",
      "offset": 11,
      "type": "uint8",
      "condition": {
        "min": 1,
        "max": 250
      },
      "comment": "Heart rate from connected HR strap (if available)"
    }
  ],

  "computed": [
    {
      "name": "_resFactor",
      "operation": "exponential",
      "operands": ["resistance"],
      "base": 1.090112,
      "comment": "1.090112^resistance — exponential resistance component"
    },
    {
      "name": "_cadFactor",
      "operation": "exponential",
      "operands": ["cadence"],
      "base": 1.015343,
      "comment": "1.015343^cadence — exponential cadence component"
    },
    {
      "name": "power",
      "operation": "multiply",
      "operands": ["_resFactor", "_cadFactor"],
      "factor": 7.228958,
      "comment": "power = 1.090112^resistance * 1.015343^cadence * 7.228958 (community formula from snowzach/echbt)"
    }
  ]
}
